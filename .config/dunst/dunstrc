[global]
    font = JetBrainsMono Nerd Font 11

    markup = full
    format = "<b>%s</b>\n%b"

    sort = yes
    indicate_hidden = yes
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = no

    width = 380
    height = 90

    origin = top-right
    offset = 20x20

    padding = 14
    horizontal_padding = 14
    text_icon_padding = 12

    alignment = left
    vertical_alignment = center

    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    corner_radius = 14
    frame_width = 1
    separator_height = 0

    background = "#1e222b"
    foreground = "#cbd5e1"
    frame_color = "#2a2f3a"

    transparency = 0

    ellipsize = middle
    ignore_newline = no

    idle_threshold = 120

    show_age_threshold = 60

[urgency_low]
    background = "#1e222b"
    foreground = "#cbd5e1"
    frame_color = "#2a2f3a"
    timeout = 4

[urgency_normal]
    background = "#1e222b"
    foreground = "#cbd5e1"
    frame_color = "#2a2f3a"
    timeout = 8

[urgency_critical]
    background = "#1e222b"
    foreground = "#ff5f5f"
    frame_color = "#ff5f5f"
    timeout = 0
